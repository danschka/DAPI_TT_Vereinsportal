{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "TT_Website: Debug",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build TT_Website",
            "program": "${workspaceFolder}/TT_Website/bin/Debug/net10.0/TT_Website.dll",
            "args": [],
            "cwd": "${workspaceFolder}/TT_Website",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ]
}
