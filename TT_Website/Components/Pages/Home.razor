@page "/"

@using TT_Website.Models
@using TT_Website.Services

@inject NewsService NewsService
@inject GalleryService GalleryService
@inject SponsorService SponsorService
@inject ContentPageService ContentPageService

<div class="preview-home">
    <section class="preview-hero">
        <PageSlideshow PageKey="home"
                       CssClass="preview-hero-slideshow"
                       ShowOverlay="true" />

        <div class="preview-hero__content">
            <p class="preview-kicker">TSV 1883 Bogen Tischtennis</p>
            <h1>@HomeTitle</h1>
            <p>
                @HomeSummary
                @*
                für alle, die Tischtennis spielen oder den Verein kennenlernen möchten.
                *@
            </p>

            <div class="preview-actions">
                <a class="btn btn-primary btn-lg" href="/mitglied-werden">Mitglied werden</a>
                <a class="btn btn-outline-light btn-lg" href="/training">Trainingszeiten</a>
            </div>
        </div>
    </section>

    <section class="preview-section preview-quicklinks" aria-label="Schnelleinstiege">
        <a class="preview-link-card" href="/mannschaften">
            <span>Mannschaften</span>
            <strong>Teams, Ligen und Spielpläne ansehen</strong>
        </a>
        <a class="preview-link-card" href="/news">
            <span>News</span>
            <strong>Aktuelles aus dem Verein lesen</strong>
        </a>
        <a class="preview-link-card" href="/kontakt">
            <span>Kontakt</span>
            <strong>Fragen stellen oder Probetraining anfragen</strong>
        </a>
    </section>

    <section class="preview-section">
        <div class="preview-section-header">
            <div>
                <p class="preview-kicker">Aktuell</p>
                <h2>Neuigkeiten aus dem Verein</h2>
            </div>
            <a href="/news">Alle News</a>
        </div>

        @if (latestNews.Count == 0)
        {
            <p class="preview-empty">Noch keine News vorhanden.</p>
        }
        else
        {
            <div class="preview-news-grid">
                @foreach (var post in latestNews)
                {
                    <article class="preview-news-card">
                        @if (!string.IsNullOrWhiteSpace(post.ImagePath))
                        {
                            <img src="@post.ImagePath" alt="@post.Title" />
                        }
                        <div>
                            <time datetime="@post.CreatedAt.ToString("yyyy-MM-dd")">
                                @post.CreatedAt.ToString("dd.MM.yyyy")
                            </time>
                            <h3>@post.Title</h3>
                            <p>@GetTeaser(post.Content)</p>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="preview-section preview-split">
        <div>
            <p class="preview-kicker">Training</p>
            <h2>Einsteigen, mitspielen, besser werden.</h2>
            <p>
                Jugend, Erwachsene und freies Training haben feste Zeiten. So finden neue Spielerinnen
                und Spieler schnell den passenden Einstieg.
            </p>
            <a class="btn btn-primary" href="/training">Zum Training</a>
        </div>

        <div class="preview-training-list">
            <div>
                <span>Jugend</span>
                <strong>Mo & Mi, 17:00 - 18:30 Uhr</strong>
            </div>
            <div>
                <span>Erwachsene</span>
                <strong>Mo & Mi, 19:00 - 21:30 Uhr</strong>
            </div>
            <div>
                <span>Freies Training</span>
                <strong>Fr, 18:00 - 21:00 Uhr</strong>
            </div>
        </div>
    </section>

    <section class="preview-section">
        <div class="preview-section-header">
            <div>
                <p class="preview-kicker">Galerie</p>
                <h2>Momente aus Halle und Vereinsleben</h2>
            </div>
            <a href="/gallery">Zur Galerie</a>
        </div>

        @if (latestImages.Count == 0)
        {
            <p class="preview-empty">Noch keine Bilder vorhanden.</p>
        }
        else
        {
            <div class="preview-gallery-strip">
                @foreach (var image in latestImages)
                {
                    <figure>
                        <img src="@image.ImagePath" alt="@image.Title" />
                        <figcaption>@image.Title</figcaption>
                    </figure>
                }
            </div>
        }
    </section>

    <section class="preview-section preview-sponsors">
        <div class="preview-section-header">
            <div>
                <p class="preview-kicker">Partner</p>
                <h2>Unterstützer des Vereins</h2>
            </div>
        </div>

        @if (sponsors.Count == 0)
        {
            <p class="preview-empty">Noch keine Sponsoren vorhanden.</p>
        }
        else
        {
            <div class="preview-sponsor-marquee" aria-label="Unterstützer des Vereins">
                <div class="preview-sponsor-track">
                    @foreach (var sponsor in GetSponsorLoop())
                    {
                        <a class="preview-sponsor-logo"
                           href="@GetSponsorUrl(sponsor)"
                           target="@GetSponsorTarget(sponsor)"
                           rel="@GetSponsorRel(sponsor)"
                           aria-label="@sponsor.Name">
                            @if (!string.IsNullOrWhiteSpace(sponsor.LogoPath))
                            {
                                <img src="@sponsor.LogoPath" alt="@sponsor.Name" />
                            }
                        </a>
                    }
                </div>
            </div>
        }
    </section>
</div>

@code {
    private List<NewsPost> latestNews = new();
    private List<GalleryImage> latestImages = new();
    private List<Sponsor> sponsors = new();
    private ContentPage? homePage;
    private string HomeTitle => string.IsNullOrWhiteSpace(homePage?.Title)
        ? "Training, Teamgeist und Punktspiele an einem Ort."
        : homePage.Title;
    private string HomeSummary => string.IsNullOrWhiteSpace(homePage?.Summary)
        ? "Aktuelle News, Trainingszeiten, Mannschaftsdaten und der schnelle Weg zur Mitgliedschaft für alle, die Tischtennis spielen oder den Verein kennenlernen möchten."
        : homePage.Summary;

    protected override async Task OnInitializedAsync()
    {
        homePage = await ContentPageService.GetBySlugAsync("startseite");
        latestNews = await NewsService.GetLatestAsync(3);
        latestImages = await GalleryService.GetLatestAsync(4);
        sponsors = await SponsorService.GetActiveAsync();
    }

    private static string GetTeaser(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return "Mehr Informationen folgen in Kürze.";
        }

        return text.Length <= 140 ? text : $"{text[..137]}...";
    }

    private IEnumerable<Sponsor> GetSponsorLoop()
    {
        return sponsors.Concat(sponsors);
    }

    private static string GetSponsorUrl(Sponsor sponsor)
    {
        return string.IsNullOrWhiteSpace(sponsor.WebsiteUrl) ? "#" : sponsor.WebsiteUrl;
    }

    private static string? GetSponsorTarget(Sponsor sponsor)
    {
        return string.IsNullOrWhiteSpace(sponsor.WebsiteUrl) ? null : "_blank";
    }

    private static string? GetSponsorRel(Sponsor sponsor)
    {
        return string.IsNullOrWhiteSpace(sponsor.WebsiteUrl) ? null : "noopener noreferrer";
    }
}
