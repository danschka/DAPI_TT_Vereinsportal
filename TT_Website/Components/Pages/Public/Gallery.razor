@page "/gallery"

@using TT_Website.Models
@using TT_Website.Services

@inject GalleryService GalleryService

<EditablePublicPageHeader Slug="galerie"
                          Eyebrow="Galerie"
                          DefaultTitle="Bildergalerie"
                          DefaultSummary="Bilder aus Training, Spielbetrieb, Aktionen und Vereinsleben."
                          ShowContent="true" />

@if (images.Count == 0)
{
    <section class="content-card empty-state">
        <h2>Noch keine Bilder vorhanden</h2>
        <p class="text-muted">Sobald Bilder bereitgestellt wurden, erscheinen sie hier.</p>
    </section>
}
else
{
    <div class="gallery-grid">
        @foreach (var image in images)
        {
            <div class="gallery-card">
                <img src="@image.ImagePath" alt="@image.Title" />
                <p>@image.Title</p>
            </div>
        }
    </div>
}

@code {
    private List<GalleryImage> images = new();

    protected override async Task OnInitializedAsync()
    {
        images = await GalleryService.GetAllAsync();
    }
}
