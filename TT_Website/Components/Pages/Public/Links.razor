@page "/links"

<EditablePublicPageHeader Slug="links"
                          Eyebrow="Verein"
                          DefaultTitle="Links"
                          DefaultSummary="Social Media, Webshop und weitere wichtige Anlaufstellen."
                          ShowContent="true" />

<section class="cms-section-list">
    <article class="content-card cms-text-card">
        <p class="cms-text-card__question">Social Media</p>
        <p>Unsere Kanäle findest du hier gesammelt.</p>

        <div class="button-row">
            <a class="btn btn-outline-primary" href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer">
                Instagram
            </a>
            <a class="btn btn-outline-primary" href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer">
                Facebook
            </a>
            <a class="btn btn-outline-primary" href="https://www.youtube.com/" target="_blank" rel="noopener noreferrer">
                YouTube
            </a>
        </div>
    </article>

    <article class="content-card cms-text-card">
        <p class="cms-text-card__question">Webshop</p>
        <p>Vereinskleidung und Zubehör findest du in unserem Webshop.</p>

        <a class="btn btn-primary" href="https://www.example.com" target="_blank" rel="noopener noreferrer">
            Zum Webshop
        </a>
    </article>
</section>
