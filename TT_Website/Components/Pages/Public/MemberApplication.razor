@page "/mitglied-werden"
@rendermode InteractiveServer

@using System.Net.Mail
@using TT_Website.Models
@using TT_Website.Services

@inject MemberApplicationService MemberApplicationService
@inject EmailService EmailService

<section class="page-hero compact">
    <p class="eyebrow">Mitgliedschaft</p>
    <h1>Mitglied werden</h1>
    <p>Schick uns deine Daten. Der Verein meldet sich anschließend bei dir.</p>
</section>

<EditablePublicPageHeader Slug="aufnahmeerklaerung"
                          Eyebrow="Mitgliedschaft"
                          DefaultTitle="Mitglied werden"
                          RenderHero="false"
                          ShowContent="true" />

<section class="content-card form-card">
    <div class="form-row">
        <div>
            <label class="form-label">Vorname</label>
            <InputText class="form-control" @bind-Value="application.FirstName" />
        </div>
        <div>
            <label class="form-label">Nachname</label>
            <InputText class="form-control" @bind-Value="application.LastName" />
        </div>
    </div>

    <div class="form-row">
        <div>
            <label class="form-label">E-Mail</label>
            <InputText class="form-control" @bind-Value="application.Email" />
        </div>
        <div>
            <label class="form-label">Telefon</label>
            <InputText class="form-control" @bind-Value="application.Phone" />
        </div>
    </div>

    <div class="form-row">
        <div>
            <label class="form-label">Geburtsdatum</label>
            <InputDate class="form-control" @bind-Value="application.BirthDate" />
        </div>
        <div>
            <label class="form-label">Adresse</label>
            <InputText class="form-control" @bind-Value="application.Address" />
        </div>
    </div>

    <label class="form-check">
        <InputCheckbox @bind-Value="application.PrivacyPolicyAccepted" />
        <span>
            Ich habe die <a href="/datenschutz" target="_blank" rel="noopener noreferrer">Datenschutzerklärung</a>
            gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung des Mitgliedsantrags zu.
        </span>
    </label>

    <button class="btn btn-primary" type="button" @onclick="SubmitApplication">Antrag absenden</button>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert @messageClass">@message</div>
    }
</section>

@code {
    private MembershipApplication application = CreateEmptyApplication();
    private string message = "";
    private string messageClass = "alert-info";

    private async Task SubmitApplication()
    {
        if (!ValidateApplication())
            return;

        application.FirstName = application.FirstName.Trim();
        application.LastName = application.LastName.Trim();
        application.Email = application.Email.Trim();
        application.Phone = application.Phone.Trim();
        application.Address = application.Address.Trim();
        application.SubmittedAt = DateTime.Now;
        application.PrivacyPolicyAcceptedAt = DateTime.Now;

        await MemberApplicationService.AddAsync(application);

        try
        {
            await EmailService.SendMemberApplicationEmailAsync(
                application.FirstName,
                application.LastName,
                application.Email,
                application.Phone,
                application.BirthDate,
                application.Address);

            SetMessage("Dein Antrag wurde erfolgreich gespeichert und per E-Mail versendet.", "alert-success");
        }
        catch (InvalidOperationException ex)
        {
            SetMessage($"Dein Antrag wurde gespeichert. {ex.Message}", "alert-warning");
        }
        catch
        {
            SetMessage("Dein Antrag wurde gespeichert. Der E-Mail-Versand ist aktuell noch nicht eingerichtet.", "alert-warning");
        }

        application = CreateEmptyApplication();
    }

    private bool ValidateApplication()
    {
        if (string.IsNullOrWhiteSpace(application.FirstName) ||
            string.IsNullOrWhiteSpace(application.LastName) ||
            string.IsNullOrWhiteSpace(application.Email) ||
            string.IsNullOrWhiteSpace(application.Address))
        {
            SetMessage("Bitte Vorname, Nachname, E-Mail und Adresse ausfüllen.", "alert-warning");
            return false;
        }

        if (!IsValidEmail(application.Email))
        {
            SetMessage("Bitte eine gültige E-Mail-Adresse eingeben.", "alert-warning");
            return false;
        }

        if (application.BirthDate.Date > DateTime.Today)
        {
            SetMessage("Das Geburtsdatum darf nicht in der Zukunft liegen.", "alert-warning");
            return false;
        }

        if (!application.PrivacyPolicyAccepted)
        {
            SetMessage("Bitte der Datenschutzerklärung zustimmen.", "alert-warning");
            return false;
        }

        return true;
    }

    private void SetMessage(string value, string cssClass)
    {
        message = value;
        messageClass = cssClass;
    }

    private static bool IsValidEmail(string email)
    {
        try
        {
            _ = new MailAddress(email);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private static MembershipApplication CreateEmptyApplication()
    {
        return new MembershipApplication
        {
            BirthDate = DateTime.Today
        };
    }
}
