@page "/sponsors"

@using TT_Website.Models
@using TT_Website.Services

@inject SponsorService SponsorService

<EditablePublicPageHeader Slug="sponsoren"
                          Eyebrow="Partner"
                          DefaultTitle="Sponsoren"
                          DefaultSummary="Diese Unternehmen unterstützen unseren Verein und das Tischtennis in Bogen."
                          ShowContent="true" />

@if (sponsors.Count == 0)
{
    <section class="content-card">
        <p class="text-muted">Keine Sponsoren vorhanden.</p>
    </section>
}
else
{
    <section class="content-card sponsor-showcase">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Unterstützer</p>
                <h2>Partner des TSV 1883 Bogen Tischtennis</h2>
            </div>
            <span>@sponsors.Count aktive Sponsoren</span>
        </div>

        <div class="sponsor-marquee" aria-label="Sponsorenlogos">
            <div class="sponsor-track">
                @foreach (var sponsor in GetMarqueeSponsors())
                {
                    <a class="sponsor-logo-tile"
                       href="@GetSponsorUrl(sponsor)"
                       target="@GetSponsorTarget(sponsor)"
                       rel="@GetSponsorRel(sponsor)"
                       aria-label="@sponsor.Name">
                        @if (!string.IsNullOrWhiteSpace(sponsor.LogoPath))
                        {
                            <img src="@sponsor.LogoPath" alt="@sponsor.Name" />
                        }
                        else
                        {
                            <strong>@sponsor.Name</strong>
                        }
                    </a>
                }
            </div>
        </div>
    </section>
}

@code {
    private List<Sponsor> sponsors = new();

    protected override async Task OnInitializedAsync()
    {
        sponsors = await SponsorService.GetActiveAsync();
    }

    private IEnumerable<Sponsor> GetMarqueeSponsors()
    {
        return sponsors.Concat(sponsors);
    }

    private static string GetSponsorUrl(Sponsor sponsor)
    {
        return string.IsNullOrWhiteSpace(sponsor.WebsiteUrl) ? "#" : sponsor.WebsiteUrl;
    }

    private static string? GetSponsorTarget(Sponsor sponsor)
    {
        return string.IsNullOrWhiteSpace(sponsor.WebsiteUrl) ? null : "_blank";
    }

    private static string? GetSponsorRel(Sponsor sponsor)
    {
        return string.IsNullOrWhiteSpace(sponsor.WebsiteUrl) ? null : "noopener noreferrer";
    }
}
