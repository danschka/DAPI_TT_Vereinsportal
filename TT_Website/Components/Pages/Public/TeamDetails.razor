@page "/teams/{Id:int}"
@rendermode InteractiveServer

@using System.Text.Json
@using TT_Website.Models
@using TT_Website.Services

@inject TeamService TeamService

@if (team is null)
{
    <div class="alert alert-warning">Mannschaft wurde nicht gefunden.</div>
}
else
{
    <section class="page-hero compact">
        <p class="eyebrow">@team.Category</p>
        <h1>@team.Name</h1>
        <p>Tabellen, Spielpläne und Mannschaftsstatistiken werden aus den zuletzt synchronisierten myTischtennis-Daten angezeigt.</p>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @statusCssClass">@statusMessage</div>
    }

    @if (isSyncing)
    {
        <div class="alert alert-info">myTischtennis-Daten werden automatisch aktualisiert.</div>
    }

    @if (team.Rounds.Any())
    {
        @foreach (var round in team.Rounds.OrderBy(GetRoundOrder))
        {
            var roundName = GetRoundDisplayName(round.RoundName);
            var roundData = GetRoundDisplayData(round);

            <section class="content-card">
                <div class="section-heading">
                    <div>
                        <p class="eyebrow">@roundName</p>
                        <h2>@(string.IsNullOrWhiteSpace(round.League) ? "Ligadaten" : GetLeagueDescription(round.League))</h2>
                    </div>
                    <span>@(round.LastSyncedAt is null ? "Noch nicht aktualisiert" : $"Stand {round.LastSyncedAt:dd.MM.yyyy HH:mm}")</span>
                </div>
            </section>

            <DataTableCard Title="@($"Tabelle {roundName}")"
                           EmptyMessage="Für diese Runde ist noch keine Ligatabelle verfügbar."
                           Rows="roundData.TableRows" />
            <DataTableCard Title="@($"Spielplan {roundName}")"
                           EmptyMessage="Für diese Runde ist noch kein Spielplan verfügbar."
                           Rows="roundData.ScheduleRows" />
            <DataTableCard Title="@($"Mannschaftsstatistik {roundName}")"
                           EmptyMessage="Für diese Runde ist noch keine Mannschaftsstatistik verfügbar."
                           Rows="roundData.StatisticsRows" />
        }
    }
    else
    {
        <section class="content-card">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Ligainformationen</p>
                    <h2>@(string.IsNullOrWhiteSpace(team.League) ? "Noch nicht importiert" : GetLeagueDescription(team.League))</h2>
                </div>
                <span>@(team.LastSyncedAt is null ? "Noch nicht aktualisiert" : $"Stand {team.LastSyncedAt:dd.MM.yyyy HH:mm}")</span>
            </div>
        </section>

        <DataTableCard Title="Tabelle"
                       EmptyMessage="Für diese Mannschaft ist noch keine Ligatabelle verfügbar."
                       Rows="tableRows" />
        <DataTableCard Title="Spielplan"
                       EmptyMessage="Für diese Mannschaft ist noch kein Spielplan verfügbar."
                       Rows="scheduleRows" />
        <DataTableCard Title="Mannschaftsstatistik"
                       EmptyMessage="Für diese Mannschaft ist noch keine Mannschaftsstatistik verfügbar."
                       Rows="statisticsRows" />
    }

    <a href="/mannschaften" class="btn btn-secondary">Zurück zu den Mannschaften</a>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Team? team;
    private bool isSyncing;
    private bool syncStarted;
    private string statusMessage = "";
    private string statusCssClass = "alert-info";
    private List<List<string>> tableRows = [];
    private List<List<string>> scheduleRows = [];
    private List<List<string>> statisticsRows = [];
    private Dictionary<int, RoundDisplayData> roundDisplayData = [];

    protected override async Task OnParametersSetAsync()
    {
        statusMessage = "";
        syncStarted = false;
        SetTeam(await TeamService.GetByIdAsync(Id));

        if (team is not null && !HasAnyImportedData(team))
        {
            statusCssClass = "alert-info";
            statusMessage = "Für diese Mannschaft werden die myTischtennis-Daten automatisch geladen.";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || syncStarted || team is null)
            return;

        syncStarted = true;
        isSyncing = true;
        await InvokeAsync(StateHasChanged);

        var syncResult = await TeamService.SyncTeamWithRoundsAsync(Id);
        SetTeam(await TeamService.GetByIdAsync(Id));

        isSyncing = false;

        if (syncResult.Success)
        {
            statusCssClass = "alert-success";
            statusMessage = "myTischtennis-Daten wurden aktualisiert.";
        }
        else if (team is not null && HasAnyImportedData(team))
        {
            statusCssClass = "alert-warning";
            statusMessage = $"{syncResult.Message} Die zuletzt gespeicherten Daten werden angezeigt.";
        }
        else
        {
            statusCssClass = "alert-warning";
            statusMessage = syncResult.Message;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void SetTeam(Team? loadedTeam)
    {
        team = loadedTeam;

        var importedTableRows = ParseRows(team?.TableDataJson);

        tableRows = IsScheduleTable(importedTableRows) || IsStatisticsTable(importedTableRows) ? [] : importedTableRows;
        scheduleRows = ParseRows(team?.ScheduleDataJson);
        statisticsRows = ParseRows(team?.StatisticsDataJson);

        if (!scheduleRows.Any() && IsScheduleTable(importedTableRows))
            scheduleRows = NormalizeScheduleRows(importedTableRows);

        if (!statisticsRows.Any() && IsStatisticsTable(importedTableRows))
            statisticsRows = importedTableRows;

        roundDisplayData = team?.Rounds.ToDictionary(
            round => round.Id,
            CreateRoundDisplayData) ?? [];
    }

    private static List<List<string>> ParseRows(string? data)
    {
        if (string.IsNullOrWhiteSpace(data))
            return [];

        var trimmedData = data.Trim();

        if (trimmedData.StartsWith("["))
        {
            try
            {
                return JsonSerializer.Deserialize<List<List<string>>>(trimmedData) ?? [];
            }
            catch (JsonException)
            {
                return [];
            }
        }

        return trimmedData
            .Split('\n', StringSplitOptions.RemoveEmptyEntries)
            .Select(line => line.Split('|', StringSplitOptions.TrimEntries).Where(cell => !string.IsNullOrWhiteSpace(cell)).ToList())
            .Where(row => row.Count > 0)
            .ToList();
    }

    private RoundDisplayData GetRoundDisplayData(TeamRound round)
    {
        return roundDisplayData.TryGetValue(round.Id, out var data)
            ? data
            : CreateRoundDisplayData(round);
    }

    private RoundDisplayData CreateRoundDisplayData(TeamRound round)
    {
        var importedTableRows = ParseRows(round.TableDataJson);
        var displayTableRows = IsScheduleTable(importedTableRows) || IsStatisticsTable(importedTableRows) ? [] : importedTableRows;
        var displayScheduleRows = ParseRows(round.ScheduleDataJson);
        var displayStatisticsRows = ParseRows(round.StatisticsDataJson);

        if (!displayScheduleRows.Any() && IsScheduleTable(importedTableRows))
            displayScheduleRows = NormalizeScheduleRows(importedTableRows);

        if (!displayStatisticsRows.Any() && IsStatisticsTable(importedTableRows))
            displayStatisticsRows = importedTableRows;

        return new RoundDisplayData(displayTableRows, displayScheduleRows, displayStatisticsRows);
    }

    private static bool HasAnyImportedData(Team team)
    {
        if (!string.IsNullOrWhiteSpace(team.TableDataJson) ||
            !string.IsNullOrWhiteSpace(team.ScheduleDataJson) ||
            !string.IsNullOrWhiteSpace(team.StatisticsDataJson))
        {
            return true;
        }

        return team.Rounds.Any(round =>
            !string.IsNullOrWhiteSpace(round.TableDataJson) ||
            !string.IsNullOrWhiteSpace(round.ScheduleDataJson) ||
            !string.IsNullOrWhiteSpace(round.StatisticsDataJson));
    }

    private static int GetRoundOrder(TeamRound round)
    {
        return round.RoundName switch
        {
            "Vorrunde" => 1,
            "Rueckrunde" => 2,
            _ => 99
        };
    }

    private static string GetRoundDisplayName(string roundName)
    {
        return roundName == "Rueckrunde" ? "Rückrunde" : roundName;
    }

    private static bool IsScheduleTable(List<List<string>> rows)
    {
        if (rows.Count == 0)
            return false;

        var header = string.Join(" ", rows[0]);

        return header.Contains("Datum", StringComparison.OrdinalIgnoreCase) &&
            (header.Contains("Heimmannschaft", StringComparison.OrdinalIgnoreCase) ||
             header.Contains("Gastmannschaft", StringComparison.OrdinalIgnoreCase));
    }

    private static bool IsStatisticsTable(List<List<string>> rows)
    {
        if (rows.Count == 0)
            return false;

        var header = string.Join(" ", rows[0]);

        return header.Contains("Name", StringComparison.OrdinalIgnoreCase) &&
            (header.Contains("Einsätze", StringComparison.OrdinalIgnoreCase) ||
             header.Contains("Bilanz", StringComparison.OrdinalIgnoreCase) ||
             header.Contains("Gesamt", StringComparison.OrdinalIgnoreCase));
    }

    private static List<List<string>> NormalizeScheduleRows(List<List<string>> rows)
    {
        var normalizedRows = new List<List<string>>
        {
            new() { "Datum", "Zeit", "Heim", "Gast", "Ergebnis" }
        };

        foreach (var row in rows.Skip(1))
        {
            var resultIndex = row.FindLastIndex(IsResult);

            if (resultIndex < 3)
                continue;

            normalizedRows.Add(new List<string>
            {
                GetCell(row, 0),
                ExtractTime(GetCell(row, 1)),
                GetCell(row, resultIndex - 2),
                GetCell(row, resultIndex - 1),
                GetCell(row, resultIndex)
            });
        }

        return normalizedRows.Count == 1 ? [] : normalizedRows;
    }

    private static bool IsResult(string value)
    {
        return System.Text.RegularExpressions.Regex.IsMatch(value, @"^\d+\s*:\s*\d+$");
    }

    private static string ExtractTime(string value)
    {
        var match = System.Text.RegularExpressions.Regex.Match(value, @"\d{1,2}:\d{2}");
        return match.Success ? match.Value : value;
    }

    private static string GetCell(List<string> row, int index)
    {
        return index < row.Count ? row[index] : "";
    }

    private static string GetLeagueDescription(string league)
    {
        return league.Contains("myTischtennis", StringComparison.OrdinalIgnoreCase) || league.Length > 220
            ? "Ligadaten bitte neu synchronisieren."
            : league;
    }

    private sealed record RoundDisplayData(
        List<List<string>> TableRows,
        List<List<string>> ScheduleRows,
        List<List<string>> StatisticsRows);
}
