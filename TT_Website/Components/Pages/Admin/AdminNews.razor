@page "/admin/news"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using TT_Website.Models
@using TT_Website.Services

@inject NewsService NewsService
@inject FileUploadService FileUploadService

<section class="admin-page-header">
    <div>
        <p class="eyebrow">News</p>
        <h1>News verwalten</h1>
        <p class="text-muted">Meldungen erstellen, veröffentlichen und bearbeiten.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @messageClass">@message</div>
}

<section class="content-card form-card">
    <h2>Neue News</h2>

    <label class="form-label">Titel</label>
    <InputText class="form-control" @bind-Value="title" placeholder="Titel" />

    <label class="form-label">Inhalt</label>
    <InputTextArea class="form-control textarea-lg" @bind-Value="content" placeholder="Inhalt" />

    <label class="form-label">Bild</label>
    <InputFile class="form-control" OnChange="HandleFileSelected" />

    <label class="form-check admin-check">
        <InputCheckbox class="form-check-input" @bind-Value="isPublished" />
        <span>Veröffentlicht</span>
    </label>

    <div class="button-row">
        <button class="btn btn-primary" type="button" @onclick="AddNews">
            News speichern
        </button>
    </div>
</section>

<section class="content-card">
    <div class="section-heading">
        <div>
            <h2>Vorhandene News</h2>
            <span>@newsPosts.Count Meldung@(newsPosts.Count == 1 ? "" : "en")</span>
        </div>
    </div>

    @if (newsPosts.Count == 0)
    {
        <p class="text-muted">Keine News vorhanden.</p>
    }
    else
    {
        <div class="admin-list">
            @foreach (var post in newsPosts)
            {
                <article class="admin-list-item">
                    @if (!string.IsNullOrWhiteSpace(post.ImagePath))
                    {
                        <img class="admin-list-image" src="@post.ImagePath" alt="@post.Title" />
                    }

                    <div class="admin-list-body">
                        <div>
                            <h3>@post.Title</h3>
                            <p class="text-muted">@post.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                        </div>
                        <p>@post.Content</p>
                        <span class="badge @(post.IsPublished ? "bg-success" : "bg-secondary")">
                            @(post.IsPublished ? "Veröffentlicht" : "Entwurf")
                        </span>
                    </div>

                    <div class="button-row admin-list-actions">
                        <a class="btn btn-outline-primary" href="@($"/admin/news/edit/{post.Id}")">
                            Bearbeiten
                        </a>
                        <button class="btn btn-outline-secondary" type="button" @onclick="() => DeleteNews(post)">
                            Löschen
                        </button>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    private List<NewsPost> newsPosts = [];
    private string title = "";
    private string content = "";
    private bool isPublished = true;
    private string message = "";
    private string messageClass = "alert-info";
    private IBrowserFile? selectedFile;

    protected override async Task OnInitializedAsync()
    {
        await LoadNews();
    }

    private async Task LoadNews()
    {
        newsPosts = await NewsService.GetAllAsync();
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task AddNews()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(title) ||
                string.IsNullOrWhiteSpace(content))
            {
                SetMessage("Bitte Titel und Inhalt eingeben.", "alert-warning");
                return;
            }

            string? imagePath = null;

            if (selectedFile != null)
            {
                imagePath = await FileUploadService.SaveAsync(
                    selectedFile,
                    "news",
                    UploadFileKind.Image,
                    10 * 1024 * 1024);
            }

            var newsPost = new NewsPost
            {
                Title = title.Trim(),
                Content = content.Trim(),
                ImagePath = imagePath,
                IsPublished = isPublished,
                CreatedAt = DateTime.Now
            };

            await NewsService.AddAsync(newsPost);

            title = "";
            content = "";
            isPublished = true;
            selectedFile = null;
            SetMessage("News wurde gespeichert.", "alert-success");

            await LoadNews();
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, "alert-danger");
        }
    }

    private async Task DeleteNews(NewsPost post)
    {
        FileUploadService.DeleteIfExists(post.ImagePath);
        await NewsService.DeleteAsync(post.Id);
        SetMessage("News wurde gelöscht.", "alert-info");
        await LoadNews();
    }

    private void SetMessage(string value, string cssClass)
    {
        message = value;
        messageClass = cssClass;
    }
}
