@page "/admin/sponsors"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using TT_Website.Models
@using TT_Website.Services

@inject SponsorService SponsorService
@inject FileUploadService FileUploadService

<section class="admin-page-header">
    <div>
        <p class="eyebrow">Sponsoren</p>
        <h1>Sponsoren verwalten</h1>
        <p class="text-muted">Sponsoren, Logos und externe Links pflegen.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @messageClass">@message</div>
}

<section class="content-card form-card">
    <h2>@(editMode ? "Sponsor bearbeiten" : "Sponsor hinzufügen")</h2>

    <div class="form-row">
        <div>
            <label class="form-label">Sponsorname</label>
            <InputText class="form-control" @bind-Value="name" placeholder="Sponsorname" />
        </div>
        <div>
            <label class="form-label">Website URL</label>
            <InputText class="form-control" @bind-Value="websiteUrl" placeholder="Website URL" />
        </div>
    </div>

    @if (editMode && !string.IsNullOrWhiteSpace(existingLogoPath))
    {
        <label class="form-label">Aktuelles Logo</label>
        <img class="admin-preview-image" src="@existingLogoPath" alt="@name" />

        <label class="form-check admin-check">
            <InputCheckbox class="form-check-input" @bind-Value="removeLogo" />
            <span>Logo entfernen</span>
        </label>
    }

    <label class="form-label">Logo</label>
    <InputFile class="form-control" OnChange="HandleFileSelected" />

    <label class="form-check admin-check">
        <InputCheckbox class="form-check-input" @bind-Value="isActive" />
        <span>Aktiv anzeigen</span>
    </label>

    <div class="button-row">
        <button class="btn btn-primary" type="button" @onclick="SaveSponsor">
            @(editMode ? "Änderungen speichern" : "Sponsor hinzufügen")
        </button>

        @if (editMode)
        {
            <button class="btn btn-outline-secondary" type="button" @onclick="CancelEdit">
                Abbrechen
            </button>
        }
    </div>
</section>

<section class="content-card">
    <div class="section-heading">
        <div>
            <h2>Vorhandene Sponsoren</h2>
            <span>@sponsors.Count Sponsor@(sponsors.Count == 1 ? "" : "en")</span>
        </div>
    </div>

    @if (sponsors.Count == 0)
    {
        <p class="text-muted">Keine Sponsoren vorhanden.</p>
    }
    else
    {
        <div class="sponsor-grid">
            @foreach (var sponsor in sponsors)
            {
                <article class="sponsor-card admin-sponsor-card">
                    @if (!string.IsNullOrWhiteSpace(sponsor.LogoPath))
                    {
                        <img src="@sponsor.LogoPath" alt="@sponsor.Name" />
                    }

                    <h3>@sponsor.Name</h3>
                    @if (!string.IsNullOrWhiteSpace(sponsor.WebsiteUrl))
                    {
                        <a href="@sponsor.WebsiteUrl" target="_blank" rel="noopener noreferrer">@sponsor.WebsiteUrl</a>
                    }

                    <p>
                        <span class="badge @(sponsor.IsActive ? "bg-success" : "bg-secondary")">
                            @(sponsor.IsActive ? "Aktiv" : "Inaktiv")
                        </span>
                    </p>

                    <div class="button-row">
                        <button class="btn btn-outline-primary" type="button" @onclick="() => StartEdit(sponsor)">
                            Bearbeiten
                        </button>

                        <button class="btn btn-outline-secondary" type="button" @onclick="() => DeleteSponsor(sponsor)">
                            Löschen
                        </button>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    private List<Sponsor> sponsors = [];
    private string name = "";
    private string? websiteUrl = "";
    private bool isActive = true;
    private IBrowserFile? selectedFile;
    private string message = "";
    private string messageClass = "alert-info";
    private bool editMode;
    private int? editingSponsorId;
    private string? existingLogoPath;
    private bool removeLogo;

    protected override async Task OnInitializedAsync()
    {
        await LoadSponsors();
    }

    private async Task LoadSponsors()
    {
        sponsors = await SponsorService.GetAllAsync();
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task SaveSponsor()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(name))
            {
                SetMessage("Bitte Sponsorname eingeben.", "alert-warning");
                return;
            }

            string? logoPath = null;

            if (selectedFile != null)
            {
                logoPath = await FileUploadService.SaveAsync(
                    selectedFile,
                    "sponsors",
                    UploadFileKind.Image,
                    10 * 1024 * 1024);
            }

            if (editMode && editingSponsorId.HasValue)
            {
                if ((removeLogo || logoPath != null) && !string.IsNullOrWhiteSpace(existingLogoPath))
                {
                    FileUploadService.DeleteIfExists(existingLogoPath);
                }

                var sponsor = new Sponsor
                {
                    Id = editingSponsorId.Value,
                    Name = name.Trim(),
                    WebsiteUrl = NormalizeUrl(websiteUrl),
                    LogoPath = removeLogo ? null : logoPath ?? existingLogoPath,
                    IsActive = isActive
                };

                await SponsorService.UpdateAsync(sponsor);
                SetMessage("Sponsor wurde aktualisiert.", "alert-success");
            }
            else
            {
                var sponsor = new Sponsor
                {
                    Name = name.Trim(),
                    WebsiteUrl = NormalizeUrl(websiteUrl),
                    LogoPath = logoPath,
                    IsActive = isActive
                };

                await SponsorService.AddAsync(sponsor);
                SetMessage("Sponsor wurde gespeichert.", "alert-success");
            }

            ResetForm();
            await LoadSponsors();
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, "alert-danger");
        }
    }

    private async Task DeleteSponsor(Sponsor sponsor)
    {
        FileUploadService.DeleteIfExists(sponsor.LogoPath);
        await SponsorService.DeleteAsync(sponsor.Id);
        SetMessage("Sponsor wurde gelöscht.", "alert-info");
        await LoadSponsors();
    }

    private void StartEdit(Sponsor sponsor)
    {
        editingSponsorId = sponsor.Id;
        name = sponsor.Name;
        websiteUrl = sponsor.WebsiteUrl;
        isActive = sponsor.IsActive;
        existingLogoPath = sponsor.LogoPath;
        selectedFile = null;
        removeLogo = false;
        editMode = true;
        SetMessage($"Bearbeite '{sponsor.Name}'.", "alert-info");
    }

    private void CancelEdit()
    {
        ResetForm();
        SetMessage("Bearbeitung abgebrochen.", "alert-info");
    }

    private void ResetForm()
    {
        name = "";
        websiteUrl = "";
        selectedFile = null;
        isActive = true;
        editMode = false;
        editingSponsorId = null;
        existingLogoPath = null;
        removeLogo = false;
    }

    private void SetMessage(string value, string cssClass)
    {
        message = value;
        messageClass = cssClass;
    }

    private static string? NormalizeUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return null;

        url = url.Trim();

        if (!url.StartsWith("http://") &&
            !url.StartsWith("https://"))
        {
            url = "https://" + url;
        }

        return url;
    }
}
