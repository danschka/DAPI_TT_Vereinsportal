@page "/admin/news/edit/{Id:int}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using TT_Website.Models
@using TT_Website.Services

@inject NewsService NewsService
@inject NavigationManager NavigationManager
@inject FileUploadService FileUploadService

<h1>News bearbeiten</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <p>@message</p>
}

@if (newsPost == null)
{
    <p>News wird geladen...</p>
}
else
{
    <div>
        <label>Titel</label><br />
        <InputText @bind-Value="newsPost.Title" />
    </div>

    <br />

    <div>
        <label>Inhalt</label><br />
        <InputTextArea @bind-Value="newsPost.Content" />
    </div>

    <br />

    @if (!string.IsNullOrWhiteSpace(newsPost.ImagePath))
    {
        <div>
            <label>Aktuelles Bild</label><br />
            <img src="@newsPost.ImagePath" alt="@newsPost.Title" style="max-width:200px;" />
        </div>

        <br />

        <label>
            <InputCheckbox @bind-Value="removeImage" />
            Bild entfernen
        </label>

        <br />
        <br />
    }

    <div>
        <label>Neues Bild</label><br />
        <InputFile OnChange="HandleFileSelected" />
    </div>

    <br />

    <label>
        <InputCheckbox @bind-Value="newsPost.IsPublished" />
        Veröffentlicht
    </label>

    <br />
    <br />

    <button type="button" @onclick="SaveNews">
        Speichern
    </button>

    <button type="button" @onclick="Cancel">
        Abbrechen
    </button>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private NewsPost? newsPost;
    private string message = "";
    private IBrowserFile? selectedFile;
    private bool removeImage;

    protected override async Task OnInitializedAsync()
    {
        newsPost = await NewsService.GetByIdAsync(Id);

        if (newsPost == null)
        {
            message = "News wurde nicht gefunden.";
        }
    }

    private async Task SaveNews()
    {
        try
        {
            if (newsPost == null)
                return;

            if (string.IsNullOrWhiteSpace(newsPost.Title) ||
                string.IsNullOrWhiteSpace(newsPost.Content))
            {
                message = "Bitte Titel und Inhalt eingeben.";
                return;
            }

            if (removeImage && !string.IsNullOrWhiteSpace(newsPost.ImagePath))
            {
                FileUploadService.DeleteIfExists(newsPost.ImagePath);
                newsPost.ImagePath = null;
            }

            if (selectedFile != null)
            {
                FileUploadService.DeleteIfExists(newsPost.ImagePath);

                newsPost.ImagePath = await FileUploadService.SaveAsync(
                    selectedFile,
                    "news",
                    UploadFileKind.Image,
                    10 * 1024 * 1024);
            }

            await NewsService.UpdateAsync(newsPost);

            NavigationManager.NavigateTo("/admin/news");
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/admin/news");
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }
}
