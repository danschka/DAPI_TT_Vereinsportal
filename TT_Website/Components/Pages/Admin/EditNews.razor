@page "/admin/news/edit/{Id:int}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using TT_Website.Models
@using TT_Website.Services

@inject NewsService NewsService
@inject NavigationManager NavigationManager
@inject FileUploadService FileUploadService

<section class="admin-page-header">
    <div>
        <p class="eyebrow">News</p>
        <h1>News bearbeiten</h1>
        <p class="text-muted">Titel, Inhalt, Bild und Veröffentlichungsstatus ändern.</p>
    </div>
    <a class="btn btn-outline-primary" href="/admin/news">Zurück</a>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-warning">@message</div>
}

@if (newsPost == null)
{
    <section class="content-card">
        <p class="text-muted">News wird geladen...</p>
    </section>
}
else
{
    <section class="content-card form-card">
        <label class="form-label">Titel</label>
        <InputText class="form-control" @bind-Value="newsPost.Title" />

        <label class="form-label">Inhalt</label>
        <InputTextArea class="form-control textarea-lg" @bind-Value="newsPost.Content" />

        @if (!string.IsNullOrWhiteSpace(newsPost.ImagePath))
        {
            <label class="form-label">Aktuelles Bild</label>
            <img class="admin-preview-image" src="@newsPost.ImagePath" alt="@newsPost.Title" />

            <label class="form-check admin-check">
                <InputCheckbox class="form-check-input" @bind-Value="removeImage" />
                <span>Bild entfernen</span>
            </label>
        }

        <label class="form-label">Neues Bild</label>
        <InputFile class="form-control" OnChange="HandleFileSelected" />

        <label class="form-check admin-check">
            <InputCheckbox class="form-check-input" @bind-Value="newsPost.IsPublished" />
            <span>Veröffentlicht</span>
        </label>

        <div class="button-row">
            <button class="btn btn-primary" type="button" @onclick="SaveNews">
                Speichern
            </button>

            <button class="btn btn-outline-secondary" type="button" @onclick="Cancel">
                Abbrechen
            </button>
        </div>
    </section>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private NewsPost? newsPost;
    private string message = "";
    private IBrowserFile? selectedFile;
    private bool removeImage;

    protected override async Task OnInitializedAsync()
    {
        newsPost = await NewsService.GetByIdAsync(Id);

        if (newsPost == null)
        {
            message = "News wurde nicht gefunden.";
        }
    }

    private async Task SaveNews()
    {
        try
        {
            if (newsPost == null)
                return;

            if (string.IsNullOrWhiteSpace(newsPost.Title) ||
                string.IsNullOrWhiteSpace(newsPost.Content))
            {
                message = "Bitte Titel und Inhalt eingeben.";
                return;
            }

            newsPost.Title = newsPost.Title.Trim();
            newsPost.Content = newsPost.Content.Trim();

            if (removeImage && !string.IsNullOrWhiteSpace(newsPost.ImagePath))
            {
                FileUploadService.DeleteIfExists(newsPost.ImagePath);
                newsPost.ImagePath = null;
            }

            if (selectedFile != null)
            {
                FileUploadService.DeleteIfExists(newsPost.ImagePath);

                newsPost.ImagePath = await FileUploadService.SaveAsync(
                    selectedFile,
                    "news",
                    UploadFileKind.Image,
                    10 * 1024 * 1024);
            }

            await NewsService.UpdateAsync(newsPost);

            NavigationManager.NavigateTo("/admin/news");
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/admin/news");
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }
}
