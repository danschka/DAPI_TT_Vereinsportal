@page "/admin"

<section class="admin-page-header">
    <div>
        <p class="eyebrow">Administration</p>
        <h1>Admin Dashboard</h1>
        <p class="text-muted">Website-Inhalte, Mannschaften, Medien und Einstellungen zentral verwalten.</p>
    </div>

    <form method="post" action="/admin/auth/logout">
        <AntiforgeryToken />
        <button class="btn btn-outline-secondary" type="submit">
            Logout
        </button>
    </form>
</section>

<section class="admin-dashboard-grid">
    <a class="admin-dashboard-card" href="/admin/pages">
        <span>Seiten</span>
        <strong>Seiten verwalten</strong>
        <p>Texte, Inhalte und Galeriezuweisungen bearbeiten.</p>
    </a>

    <a class="admin-dashboard-card" href="/admin/settings">
        <span>Einstellungen</span>
        <strong>Einstellungen verwalten</strong>
        <p>E-Mail, Rangliste und Mitgliederentwicklung pflegen.</p>
    </a>

    <a class="admin-dashboard-card" href="/admin/gallery">
        <span>Galerie</span>
        <strong>Galerie verwalten</strong>
        <p>Bildgruppen, Slideshow-Zuweisungen und Bilder organisieren.</p>
    </a>

    <a class="admin-dashboard-card" href="/admin/gallery-upload">
        <span>Upload</span>
        <strong>Bild hochladen</strong>
        <p>Neue Bilder für Galerie, Seiten und Slideshow bereitstellen.</p>
    </a>

    <a class="admin-dashboard-card" href="/admin/download-upload">
        <span>Downloads</span>
        <strong>Dokumente verwalten</strong>
        <p>PDFs und Dokumente für die öffentliche Download-Seite pflegen.</p>
    </a>

    <a class="admin-dashboard-card" href="/admin/sponsors">
        <span>Sponsoren</span>
        <strong>Sponsoren verwalten</strong>
        <p>Sponsoren, Logos und Links hinzufügen oder bearbeiten.</p>
    </a>

    <a class="admin-dashboard-card" href="/admin/member-applications">
        <span>Mitglieder</span>
        <strong>Mitgliedsanträge anzeigen</strong>
        <p>Eingegangene Mitgliedsanfragen prüfen und verwalten.</p>
    </a>

    <a class="admin-dashboard-card" href="/admin/news">
        <span>News</span>
        <strong>News verwalten</strong>
        <p>Aktuelle Meldungen erstellen, veröffentlichen und bearbeiten.</p>
    </a>

    <a class="admin-dashboard-card" href="/admin/teams">
        <span>Mannschaften</span>
        <strong>Mannschaften verwalten</strong>
        <p>Teams und myTischtennis-Links pflegen und synchronisieren.</p>
    </a>
</section>
