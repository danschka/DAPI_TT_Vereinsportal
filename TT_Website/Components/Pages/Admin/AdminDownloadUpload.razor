@page "/admin/download-upload"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using TT_Website.Models
@using TT_Website.Services

@inject DownloadService DownloadService
@inject FileUploadService FileUploadService

<h1>Downloads verwalten</h1>

<section class="content-card form-card">
    <h2>Dokument hochladen</h2>

    <label class="form-label">Titel</label>
    <InputText class="form-control" @bind-Value="title" placeholder="Titel des Dokuments" />

    <label class="form-label">Datei</label>
    <InputFile class="form-control" OnChange="HandleFileSelected" />

    <div class="button-row">
        <button class="btn btn-primary" type="button" @onclick="UploadDocument">
            Hochladen
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert @messageClass">@message</div>
    }
</section>

<section class="content-card">
    <div class="section-heading">
        <div>
            <h2>Vorhandene Dokumente</h2>
            <span>@documents.Count Dokument@(documents.Count == 1 ? "" : "e")</span>
        </div>
    </div>

    @if (documents.Count == 0)
    {
        <p class="text-muted">Keine Dokumente vorhanden.</p>
    }
    else
    {
        <div class="download-list">
            @foreach (var document in documents)
            {
                <div class="download-card">
                    <div>
                        <p class="download-card__type">Dokument</p>
                        <h3>@document.Title</h3>
                        <p class="text-muted">Hochgeladen: @document.UploadedAt.ToString("dd.MM.yyyy HH:mm")</p>
                    </div>
                    <div class="button-row">
                        <a class="btn btn-outline-primary" href="@document.FilePath" target="_blank" rel="noopener noreferrer">
                            Öffnen
                        </a>
                        <button class="btn btn-outline-secondary" type="button" @onclick="() => DeleteDocument(document)">
                            Löschen
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</section>

@code {
    private List<DownloadDocument> documents = [];
    private IBrowserFile? selectedFile;
    private string title = "";
    private string message = "";
    private string messageClass = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        await LoadDocuments();
    }

    private async Task LoadDocuments()
    {
        documents = await DownloadService.GetAllAsync();
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task UploadDocument()
    {
        try
        {
            message = "Upload gestartet...";
            messageClass = "alert-info";

            if (selectedFile == null)
            {
                SetMessage("Bitte Datei auswählen.", "alert-warning");
                return;
            }

            if (string.IsNullOrWhiteSpace(title))
            {
                SetMessage("Bitte Titel eingeben.", "alert-warning");
                return;
            }

            var filePath = await FileUploadService.SaveAsync(
                selectedFile,
                "documents",
                UploadFileKind.Document,
                20 * 1024 * 1024);

            var document = new DownloadDocument
            {
                Title = title.Trim(),
                FilePath = filePath
            };

            await DownloadService.AddAsync(document);

            title = "";
            selectedFile = null;
            SetMessage("Dokument erfolgreich hochgeladen.", "alert-success");

            await LoadDocuments();
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, "alert-danger");
        }
    }

    private async Task DeleteDocument(DownloadDocument document)
    {
        FileUploadService.DeleteIfExists(document.FilePath);
        await DownloadService.DeleteAsync(document.Id);
        SetMessage("Dokument wurde gelöscht.", "alert-info");
        await LoadDocuments();
    }

    private void SetMessage(string value, string cssClass)
    {
        message = value;
        messageClass = cssClass;
    }
}
