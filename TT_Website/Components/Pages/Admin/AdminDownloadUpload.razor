@page "/admin/download-upload"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using TT_Website.Models
@using TT_Website.Services

@inject DownloadService DownloadService
@inject FileUploadService FileUploadService

<h1>Downloads verwalten</h1>

<div>
    <InputText @bind-Value="title" placeholder="Titel" />
</div>

<br />

<InputFile OnChange="HandleFileSelected" />

<br />
<br />

<button type="button" @onclick="UploadDocument">
    Hochladen
</button>

@if (!string.IsNullOrWhiteSpace(message))
{
    <p>@message</p>
}

<hr />

@if (documents.Count == 0)
{
    <p>Keine Dokumente vorhanden.</p>
}
else
{
    <div class="download-list">
        @foreach (var document in documents)
        {
            <div class="download-card">
                <h4>@document.Title</h4>
                <p>Hochgeladen: @document.UploadedAt.ToString("dd.MM.yyyy HH:mm")</p>
                <a href="@document.FilePath" target="_blank">Dokument öffnen</a>
                <button type="button" @onclick="() => DeleteDocument(document)">
                    Löschen
                </button>
            </div>
        }
    </div>
}

@code {
    private List<DownloadDocument> documents = new();
    private IBrowserFile? selectedFile;
    private string title = "";
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDocuments();
    }

    private async Task LoadDocuments()
    {
        documents = await DownloadService.GetAllAsync();
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task UploadDocument()
    {
        try
        {
            message = "Upload gestartet...";

            if (selectedFile == null)
            {
                message = "Bitte Datei auswählen.";
                return;
            }

            if (string.IsNullOrWhiteSpace(title))
            {
                message = "Bitte Titel eingeben.";
                return;
            }

            var filePath = await FileUploadService.SaveAsync(
                selectedFile,
                "documents",
                UploadFileKind.Document,
                20 * 1024 * 1024);

            var document = new DownloadDocument
            {
                Title = title,
                FilePath = filePath
            };

            await DownloadService.AddAsync(document);

            message = "Dokument erfolgreich hochgeladen.";

            title = "";
            selectedFile = null;

            await LoadDocuments();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task DeleteDocument(DownloadDocument document)
    {
        FileUploadService.DeleteIfExists(document.FilePath);
        await DownloadService.DeleteAsync(document.Id);
        message = "Dokument wurde gelöscht.";
        await LoadDocuments();
    }
}
