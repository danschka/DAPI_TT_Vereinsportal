@page "/admin/member-applications"
@rendermode InteractiveServer

@using TT_Website.Models
@using TT_Website.Services

@inject MemberApplicationService MemberApplicationService

<h1>Mitgliedsanträge</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <p>@message</p>
}

@if (applications.Count == 0)
{
    <p>Keine Mitgliedsanträge vorhanden.</p>
}
else
{
    @foreach (var application in applications)
    {
        <div>
            <h4>@application.FirstName @application.LastName</h4>
            <p>E-Mail: @application.Email</p>
            <p>Telefon: @application.Phone</p>
            <p>Geburtsdatum: @application.BirthDate.ToString("dd.MM.yyyy")</p>
            <p>Adresse: @application.Address</p>
            <p>Datenschutz akzeptiert: @(application.PrivacyPolicyAccepted ? "Ja" : "Nein")</p>
            @if (application.PrivacyPolicyAcceptedAt.HasValue)
            {
                <p>Akzeptiert am: @application.PrivacyPolicyAcceptedAt.Value.ToString("dd.MM.yyyy HH:mm")</p>
            }
            <p>Eingereicht: @application.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</p>

            <button type="button" @onclick="() => DeleteApplication(application.Id)">
                Löschen
            </button>

            <hr />
        </div>
    }
}

@code {
    private List<MembershipApplication> applications = new();
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadApplications();
    }

    private async Task LoadApplications()
    {
        applications = await MemberApplicationService.GetAllAsync();
    }

    private async Task DeleteApplication(int id)
    {
        await MemberApplicationService.DeleteAsync(id);

        message = "Mitgliedsantrag wurde gelöscht.";

        await LoadApplications();
    }
}
