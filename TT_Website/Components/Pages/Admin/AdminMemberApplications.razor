@page "/admin/member-applications"
@rendermode InteractiveServer

@using TT_Website.Models
@using TT_Website.Services

@inject MemberApplicationService MemberApplicationService

<section class="admin-page-header">
    <div>
        <p class="eyebrow">Mitglieder</p>
        <h1>Mitgliedsanträge</h1>
        <p class="text-muted">Eingegangene Mitgliedsanfragen prüfen und verwalten.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info">@message</div>
}

<section class="content-card">
    <div class="section-heading">
        <div>
            <h2>Anträge</h2>
            <span>@applications.Count Antrag@(applications.Count == 1 ? "" : "e")</span>
        </div>
    </div>

    @if (applications.Count == 0)
    {
        <p class="text-muted">Keine Mitgliedsanträge vorhanden.</p>
    }
    else
    {
        <div class="admin-list">
            @foreach (var application in applications)
            {
                <article class="admin-list-item">
                    <div class="admin-list-body">
                        <div>
                            <h3>@application.FirstName @application.LastName</h3>
                            <p class="text-muted">Eingereicht: @application.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</p>
                        </div>

                        <dl class="admin-detail-list">
                            <div>
                                <dt>E-Mail</dt>
                                <dd>@application.Email</dd>
                            </div>
                            <div>
                                <dt>Telefon</dt>
                                <dd>@application.Phone</dd>
                            </div>
                            <div>
                                <dt>Geburtsdatum</dt>
                                <dd>@application.BirthDate.ToString("dd.MM.yyyy")</dd>
                            </div>
                            <div>
                                <dt>Adresse</dt>
                                <dd>@application.Address</dd>
                            </div>
                            <div>
                                <dt>Datenschutz</dt>
                                <dd>@(application.PrivacyPolicyAccepted ? "Akzeptiert" : "Nicht akzeptiert")</dd>
                            </div>
                            @if (application.PrivacyPolicyAcceptedAt.HasValue)
                            {
                                <div>
                                    <dt>Akzeptiert am</dt>
                                    <dd>@application.PrivacyPolicyAcceptedAt.Value.ToString("dd.MM.yyyy HH:mm")</dd>
                                </div>
                            }
                        </dl>
                    </div>

                    <div class="button-row admin-list-actions">
                        <button class="btn btn-outline-secondary" type="button" @onclick="() => DeleteApplication(application.Id)">
                            Löschen
                        </button>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    private List<MembershipApplication> applications = [];
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadApplications();
    }

    private async Task LoadApplications()
    {
        applications = await MemberApplicationService.GetAllAsync();
    }

    private async Task DeleteApplication(int id)
    {
        await MemberApplicationService.DeleteAsync(id);
        message = "Mitgliedsantrag wurde gelöscht.";
        await LoadApplications();
    }
}
