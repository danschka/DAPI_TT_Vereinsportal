@page "/admin/teams"
@rendermode InteractiveServer

@using TT_Website.Models
@using TT_Website.Services

@inject TeamService TeamService

<h3>Mannschaften verwalten</h3>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @statusCssClass">@statusMessage</div>
}

<div class="card p-4 mb-4">
    <h5>@(editMode ? "Mannschaft bearbeiten" : "Neue Mannschaft")</h5>

    <div class="mb-3">
        <label class="form-label">Name</label>
        <input class="form-control" @bind="currentTeam.Name" />
    </div>

    <div class="mb-3">
        <label class="form-label">Kategorie</label>
        <select class="form-select" @bind="currentTeam.Category">
            <option value="Damen">Damen</option>
            <option value="Herren">Herren</option>
            <option value="Jugend">Jugend</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">myTischtennis Tabellen-/Statistik-URL</label>
        <input class="form-control" @bind="currentTeam.MyTischtennisLeagueUrl" />
    </div>

    <div class="mb-3">
        <label class="form-label">myTischtennis Spielplan-URL</label>
        <input class="form-control" @bind="currentTeam.MyTischtennisScheduleUrl" />
    </div>

    @if (currentTeam.Category == "Jugend")
    {
        <div class="alert alert-info">
            Jugendmannschaften können getrennte Links für Vor- und Rückrunde haben.
        </div>

        <div class="mb-3">
            <label class="form-label">Vorrunde Tabellen-/Statistik-URL</label>
            <input class="form-control" @bind="firstRoundUrl" />
        </div>

        <div class="mb-3">
            <label class="form-label">Vorrunde Spielplan-URL</label>
            <input class="form-control" @bind="firstRoundScheduleUrl" />
        </div>

        <div class="mb-3">
            <label class="form-label">Rückrunde Tabellen-/Statistik-URL</label>
            <input class="form-control" @bind="secondRoundUrl" />
        </div>

        <div class="mb-3">
            <label class="form-label">Rückrunde Spielplan-URL</label>
            <input class="form-control" @bind="secondRoundScheduleUrl" />
        </div>
    }

    <div class="form-check mb-3">
        <input class="form-check-input"
               type="checkbox"
               @bind="currentTeam.IsActive" />

        <label class="form-check-label">
            Aktiv anzeigen
        </label>
    </div>

    @if (editMode)
    {
        <button type="button" class="btn btn-success me-2" @onclick="UpdateTeam">
            Änderungen speichern
        </button>

        <button type="button" class="btn btn-secondary" @onclick="CancelEdit">
            Abbrechen
        </button>
    }
    else
    {
        <button type="button" class="btn btn-primary" @onclick="CreateTeam">
            Mannschaft anlegen
        </button>
    }
</div>

@if (!teams.Any())
{
    <div class="alert alert-warning">
        Noch keine Mannschaften vorhanden.
    </div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Kategorie</th>
                <th>Status</th>
                <th>URL</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var team in teams)
            {
                <tr>
                    <td>@team.Id</td>
                    <td>@team.Name</td>
                    <td>@team.Category</td>

                    <td>
                        @if (team.IsActive)
                        {
                            <span class="badge bg-success">Aktiv</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inaktiv</span>
                        }
                    </td>

                    <td>
                        @if (!string.IsNullOrWhiteSpace(team.MyTischtennisLeagueUrl))
                        {
                            <a href="@team.MyTischtennisLeagueUrl" target="_blank">
                                Öffnen
                            </a>
                        }
                        @if (team.Rounds.Count > 0)
                        {
                            <div class="text-muted small">
                                @team.Rounds.Count Runden-Link(s)
                            </div>
                        }
                    </td>

                    <td class="text-end">
                        <button type="button"
                                class="btn btn-warning btn-sm me-2"
                                @onclick="() => StartEdit(team)">
                            Bearbeiten
                        </button>

                        <button type="button"
                                class="btn btn-danger btn-sm"
                                @onclick="() => DeleteTeam(team.Id)">
                            Löschen
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Team> teams = [];

    private Team currentTeam = new()
    {
        Category = "Herren",
        IsActive = true
    };

    private bool editMode = false;
    private string statusMessage = "";
    private string statusCssClass = "alert-info";
    private string? firstRoundUrl;
    private string? firstRoundScheduleUrl;
    private string? secondRoundUrl;
    private string? secondRoundScheduleUrl;

    protected override async Task OnInitializedAsync()
    {
        await LoadTeams();
    }

    private async Task LoadTeams()
    {
        teams = await TeamService.GetAllAsync();
    }

    private async Task CreateTeam()
    {
        if (string.IsNullOrWhiteSpace(currentTeam.Name))
        {
            statusCssClass = "alert-warning";
            statusMessage = "Name fehlt.";
            return;
        }

        currentTeam.IsActive = true;
        NormalizeTeamUrls();

        var syncResult = await TeamService.AddAsync(currentTeam);
        await SaveYouthRounds(currentTeam.Id);
        await LoadTeams();

        statusCssClass = syncResult.Success ? "alert-success" : "alert-warning";
        statusMessage = syncResult.Success
            ? $"Mannschaft '{currentTeam.Name}' wurde angelegt und synchronisiert."
            : $"Mannschaft '{currentTeam.Name}' wurde angelegt. {syncResult.Message}";

        ResetForm();
    }

    private void StartEdit(Team team)
    {
        currentTeam = new Team
        {
            Id = team.Id,
            Name = team.Name,
            Category = team.Category,
            MyTischtennisLeagueUrl = team.MyTischtennisStatisticsUrl ?? team.MyTischtennisLeagueUrl,
            MyTischtennisStatisticsUrl = team.MyTischtennisStatisticsUrl,
            MyTischtennisScheduleUrl = team.MyTischtennisScheduleUrl,
            IsActive = team.IsActive,
            League = team.League,
            Season = team.Season,
            TableDataJson = team.TableDataJson,
            ScheduleDataJson = team.ScheduleDataJson,
            StatisticsDataJson = team.StatisticsDataJson,
            LastSyncedAt = team.LastSyncedAt,
            Rounds = team.Rounds
        };

        firstRoundUrl = team.Rounds
            .FirstOrDefault(round => round.RoundName == "Vorrunde")
            ?.MyTischtennisStatisticsUrl ?? team.Rounds
            .FirstOrDefault(round => round.RoundName == "Vorrunde")
            ?.MyTischtennisLeagueUrl;
        firstRoundScheduleUrl = team.Rounds
            .FirstOrDefault(round => round.RoundName == "Vorrunde")
            ?.MyTischtennisScheduleUrl;

        secondRoundUrl = team.Rounds
            .FirstOrDefault(round => round.RoundName == "Rueckrunde")
            ?.MyTischtennisStatisticsUrl ?? team.Rounds
            .FirstOrDefault(round => round.RoundName == "Rueckrunde")
            ?.MyTischtennisLeagueUrl;
        secondRoundScheduleUrl = team.Rounds
            .FirstOrDefault(round => round.RoundName == "Rueckrunde")
            ?.MyTischtennisScheduleUrl;

        editMode = true;
        statusCssClass = "alert-info";
        statusMessage = $"Bearbeite '{team.Name}'.";
    }

    private async Task UpdateTeam()
    {
        if (string.IsNullOrWhiteSpace(currentTeam.Name))
        {
            statusCssClass = "alert-warning";
            statusMessage = "Name fehlt.";
            return;
        }

        NormalizeTeamUrls();
        var syncResult = await TeamService.UpdateAsync(currentTeam);
        await SaveYouthRounds(currentTeam.Id);
        await LoadTeams();

        statusCssClass = syncResult.Success ? "alert-success" : "alert-warning";
        statusMessage = syncResult.Success
            ? $"Mannschaft '{currentTeam.Name}' wurde aktualisiert und synchronisiert."
            : $"Mannschaft '{currentTeam.Name}' wurde aktualisiert. {syncResult.Message}";

        ResetForm();
    }

    private async Task DeleteTeam(int id)
    {
        await TeamService.DeleteAsync(id);
        await LoadTeams();

        statusCssClass = "alert-info";
        statusMessage = "Mannschaft wurde gelöscht.";

        ResetForm();
    }

    private void CancelEdit()
    {
        ResetForm();
        statusCssClass = "alert-info";
        statusMessage = "Bearbeitung abgebrochen.";
    }

    private void ResetForm()
    {
        currentTeam = new Team
        {
            Category = "Herren",
            IsActive = true
        };

        firstRoundUrl = null;
        firstRoundScheduleUrl = null;
        secondRoundUrl = null;
        secondRoundScheduleUrl = null;
        editMode = false;
    }

    private void NormalizeTeamUrls()
    {
        currentTeam.MyTischtennisStatisticsUrl = currentTeam.MyTischtennisLeagueUrl;
    }

    private async Task SaveYouthRounds(int teamId)
    {
        if (currentTeam.Category != "Jugend")
        {
            await TeamService.SaveRoundsAsync(
                teamId,
                new Dictionary<string, string?>
                {
                    ["Vorrunde"] = null,
                    ["Rueckrunde"] = null
                });
            return;
        }

        await TeamService.SaveRoundsAsync(
            teamId,
            new Dictionary<string, string?>
            {
                ["Vorrunde"] = firstRoundUrl,
                ["Rueckrunde"] = secondRoundUrl
            },
            new Dictionary<string, string?>
            {
                ["Vorrunde"] = firstRoundUrl,
                ["Rueckrunde"] = secondRoundUrl
            },
            new Dictionary<string, string?>
            {
                ["Vorrunde"] = firstRoundScheduleUrl,
                ["Rueckrunde"] = secondRoundScheduleUrl
            });
    }

    private int GetRoundOrder(TeamRound round)
    {
        return round.RoundName switch
        {
            "Vorrunde" => 1,
            "Rueckrunde" => 2,
            _ => 99
        };
    }

    private string GetRoundDisplayName(string roundName)
    {
        return roundName == "Rueckrunde" ? "Rückrunde" : roundName;
    }
}
