@page "/admin/login"

<section class="admin-login-page">
        <div class="admin-login-panel">
        <div class="admin-login-brand">
            <img src="/vereinslogo.png" alt="TSV 1883 Bogen Tischtennis" />
            <div>
                <p class="eyebrow">Administration</p>
                <h1>TSV 1883 Bogen</h1>
            </div>
        </div>

        <p class="admin-login-copy">
            Melde dich an, um News, Bilder, Mannschaften, Seiten und Einstellungen der Vereinswebsite zu verwalten.
        </p>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="alert @messageCss">@message</div>
        }

        <form method="post" action="/admin/auth/login" class="admin-login-form">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@returnUrl" />

            <label class="form-label" for="admin-password">Passwort</label>
            <input id="admin-password"
                   class="form-control"
                   name="password"
                   type="password"
                   autocomplete="current-password"
                   autofocus
                   required />

            <button type="submit" class="btn btn-primary admin-login-submit">
                Einloggen
            </button>
        </form>
    </div>
</section>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromQuery]
    private string? LoggedOut { get; set; }

    private string returnUrl = "/admin";
    private string message = "";
    private string messageCss = "alert-info";

    protected override void OnInitialized()
    {
        returnUrl = GetSafeAdminReturnUrl(ReturnUrl);

        if (!string.IsNullOrWhiteSpace(Error))
        {
            message = "Das Passwort ist nicht korrekt.";
            messageCss = "alert-warning";
        }

        if (!string.IsNullOrWhiteSpace(LoggedOut))
        {
            message = "Du wurdest erfolgreich ausgeloggt.";
            messageCss = "alert-success";
        }
    }

    private static string GetSafeAdminReturnUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) ||
            !value.StartsWith("/", StringComparison.Ordinal) ||
            value.StartsWith("//", StringComparison.Ordinal) ||
            !value.StartsWith("/admin", StringComparison.OrdinalIgnoreCase) ||
            value.StartsWith("/admin/auth", StringComparison.OrdinalIgnoreCase) ||
            value.StartsWith("/admin/login", StringComparison.OrdinalIgnoreCase))
        {
            return "/admin";
        }

        return value;
    }
}
