@page "/admin/pages"
@rendermode InteractiveServer

@using TT_Website.Models
@using TT_Website.Services

@inject ContentPageService ContentPageService
@inject GalleryService GalleryService

<h1>Seiteninhalte bearbeiten</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @messageClass">@message</div>
}

<section class="admin-grid">
    <div class="content-card">
        <h2>Text bearbeiten</h2>

        <label class="form-label">Seite</label>
        <InputSelect class="form-select" @bind-Value="selectedEditPageId" @bind-Value:after="LoadSelectedPage">
            <option value="0">Seite wählen</option>
            @foreach (var pageOption in pages)
            {
                <option value="@pageOption.Id">@GetPageLabel(pageOption)</option>
            }
        </InputSelect>

        @if (currentPage.Id > 0)
        {
            <div class="form-text mb-3">
                @GetPublicRoute(currentPage)
            </div>

            <label class="form-label">Seitentitel</label>
            <InputText class="form-control" @bind-Value="currentPage.Title" />

            <label class="form-label">Kurztext</label>
            <InputTextArea class="form-control" @bind-Value="currentPage.Summary" />

            <div class="admin-section-toolbar">
                <div>
                    <label class="form-label">Text-Cards</label>
                    <div class="form-text">
                        Jede Textbox wird auf der öffentlichen Seite als eigene Card angezeigt.
                    </div>
                </div>
                <button class="btn btn-outline-primary" type="button" @onclick="AddTextCard">Card hinzufügen</button>
            </div>

            <div class="admin-text-card-list">
                @for (var index = 0; index < textCards.Count; index++)
                {
                    var cardIndex = index;
                    var card = textCards[cardIndex];

                    <article class="admin-text-card-editor">
                        <div class="admin-text-card-editor__header">
                            <strong>Card @(cardIndex + 1)</strong>
                            <div class="button-row compact">
                                <button class="btn btn-outline-secondary btn-sm"
                                        type="button"
                                        disabled="@(cardIndex == 0)"
                                        @onclick="() => MoveTextCard(cardIndex, -1)">
                                    Hoch
                                </button>
                                <button class="btn btn-outline-secondary btn-sm"
                                        type="button"
                                        disabled="@(cardIndex == textCards.Count - 1)"
                                        @onclick="() => MoveTextCard(cardIndex, 1)">
                                    Runter
                                </button>
                                <button class="btn btn-outline-secondary btn-sm"
                                        type="button"
                                        disabled="@(textCards.Count == 1)"
                                        @onclick="() => RemoveTextCard(cardIndex)">
                                    Entfernen
                                </button>
                            </div>
                        </div>

                        <label class="form-label">Unterüberschrift</label>
                        <InputText class="form-control" @bind-Value="card.Heading" placeholder="z. B. Was macht uns aus?" />

                        <label class="form-label">Text</label>
                        <InputTextArea class="form-control textarea-md" @bind-Value="card.Text" />
                    </article>
                }
            </div>

            <label class="form-label">Externer Link</label>
            <InputText class="form-control" @bind-Value="currentPage.ExternalUrl" placeholder="https://..." />
            <div class="form-text mb-3">
                Optional. Wenn hier ein Link steht, öffnet der Menüpunkt direkt diese externe Seite.
            </div>

            @if (currentPage.Slug == "vereinslokal")
            {
                <label class="form-check">
                    <InputCheckbox @bind-Value="currentPage.ShowMap" />
                    Google Maps anzeigen
                </label>

                @if (currentPage.ShowMap)
                {
                    <label class="form-label">Adresse</label>
                    <InputText class="form-control" @bind-Value="currentPage.MapAddress" />

                    <label class="form-label">Optionaler Embed-Link</label>
                    <InputText class="form-control" @bind-Value="currentPage.MapEmbedUrl" />
                }
            }

            <div class="button-row">
                <button class="btn btn-primary" type="button" @onclick="SavePage">Speichern</button>
            </div>
        }
    </div>

    <div class="content-card">
        <h2>Bildgruppen zuweisen</h2>

        <label class="form-label">Seite</label>
        <InputSelect class="form-select" @bind-Value="selectedPageId">
            <option value="0">Seite wählen</option>
            @foreach (var pageOption in pages)
            {
                <option value="@pageOption.Id">@GetPageLabel(pageOption)</option>
            }
        </InputSelect>

        <label class="form-label">Bildgruppe</label>
        <InputSelect class="form-select" @bind-Value="selectedGroupId">
            <option value="0">Gruppe wählen</option>
            @foreach (var group in groups)
            {
                <option value="@group.Id">@group.Name</option>
            }
        </InputSelect>

        <button class="btn btn-primary" type="button" @onclick="AssignGroup">Bildgruppe hinzufügen</button>
    </div>
</section>

<section class="content-card">
    <h2>Seiten und Bildgruppen</h2>

    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Seite</th>
                <th>Galerien</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var contentPageItem in pages)
            {
                <tr>
                    <td>@GetPageLabel(contentPageItem)</td>
                    <td>
                        @foreach (var assignment in contentPageItem.GalleryGroups)
                        {
                            <span class="badge bg-secondary me-1">@assignment.GalleryGroup?.Name</span>
                            <button class="btn btn-link btn-sm" type="button" @onclick="() => RemoveGroup(assignment.Id)">entfernen</button>
                        }
                    </td>
                    <td class="text-end">
                        <button class="btn btn-outline-primary btn-sm" type="button" @onclick="() => EditPage(contentPageItem)">Bearbeiten</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<ContentPage> pages = [];
    private List<GalleryGroup> groups = [];
    private ContentPage currentPage = new();
    private List<EditableTextCard> textCards = [new()];
    private string message = "";
    private string messageClass = "alert-info";
    private int selectedEditPageId;
    private int selectedPageId;
    private int selectedGroupId;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        pages = await ContentPageService.GetAllAsync();
        groups = await GalleryService.GetGroupsAsync();
    }

    private void LoadSelectedPage()
    {
        var page = pages.FirstOrDefault(x => x.Id == selectedEditPageId);

        if (page is not null)
            EditPage(page);
        else
        {
            currentPage = new ContentPage();
            textCards = [new EditableTextCard()];
        }
    }

    private async Task SavePage()
    {
        if (currentPage.Id == 0)
        {
            SetMessage("Bitte zuerst eine Seite auswählen.", "alert-warning");
            return;
        }

        currentPage.Content = SerializeTextCards();
        await ContentPageService.UpdateContentAsync(currentPage);
        SetMessage("Seiteninhalt wurde gespeichert.", "alert-success");
        await LoadData();
    }

    private void EditPage(ContentPage page)
    {
        selectedEditPageId = page.Id;
        currentPage = new ContentPage
        {
            Id = page.Id,
            Title = page.Title,
            Slug = page.Slug,
            Summary = page.Summary,
            Content = page.Content,
            ExternalUrl = page.ExternalUrl,
            ShowMap = page.ShowMap,
            MapAddress = page.MapAddress,
            MapEmbedUrl = page.MapEmbedUrl
        };

        textCards = ParseTextCards(page.Content);
    }

    private void AddTextCard()
    {
        textCards.Add(new EditableTextCard());
    }

    private void RemoveTextCard(int index)
    {
        if (textCards.Count <= 1 || index < 0 || index >= textCards.Count)
            return;

        textCards.RemoveAt(index);
    }

    private void MoveTextCard(int index, int direction)
    {
        var newIndex = index + direction;

        if (index < 0 || index >= textCards.Count || newIndex < 0 || newIndex >= textCards.Count)
            return;

        (textCards[index], textCards[newIndex]) = (textCards[newIndex], textCards[index]);
    }

    private string SerializeTextCards()
    {
        return string.Join(
            $"{Environment.NewLine}{Environment.NewLine}",
            textCards
                .Where(card => !string.IsNullOrWhiteSpace(card.Heading) || !string.IsNullOrWhiteSpace(card.Text))
                .Select(card =>
                {
                    var heading = card.Heading?.Trim() ?? "";
                    var text = card.Text?.Trim() ?? "";

                    return string.IsNullOrWhiteSpace(heading)
                        ? text
                        : $"### {heading}{Environment.NewLine}{text}";
                }));
    }

    private static List<EditableTextCard> ParseTextCards(string content)
    {
        if (string.IsNullOrWhiteSpace(content))
            return [new EditableTextCard()];

        var lines = content.Replace("\r\n", "\n").Split('\n');

        if (lines.Any(line => line.TrimStart().StartsWith("### ")))
            return ParseStructuredTextCards(lines);

        return ParseLegacyTextCards(lines);
    }

    private static List<EditableTextCard> ParseStructuredTextCards(IEnumerable<string> lines)
    {
        var cards = new List<EditableTextCard>();
        var heading = "";
        var textLines = new List<string>();

        foreach (var rawLine in lines)
        {
            var line = rawLine.TrimEnd();

            if (line.TrimStart().StartsWith("### "))
            {
                AddParsedCard(cards, heading, textLines);
                heading = line.Trim()[4..].Trim();
                textLines.Clear();
                continue;
            }

            textLines.Add(line);
        }

        AddParsedCard(cards, heading, textLines);
        return cards.Count == 0 ? [new EditableTextCard()] : cards;
    }

    private static List<EditableTextCard> ParseLegacyTextCards(IEnumerable<string> rawLines)
    {
        var lines = rawLines
            .Select(line => line.Trim())
            .Where(line => !string.IsNullOrWhiteSpace(line))
            .ToList();

        var cards = new List<EditableTextCard>();
        var textBuffer = new List<string>();

        for (var index = 0; index < lines.Count; index++)
        {
            var line = lines[index];

            if (line.EndsWith('?') && index + 1 < lines.Count)
            {
                AddParsedCard(cards, "", textBuffer);
                cards.Add(new EditableTextCard { Heading = line, Text = lines[index + 1] });
                index++;
                continue;
            }

            var questionMarkIndex = line.IndexOf('?');
            if (questionMarkIndex >= 0 && questionMarkIndex < line.Length - 1)
            {
                AddParsedCard(cards, "", textBuffer);
                cards.Add(new EditableTextCard
                {
                    Heading = line[..(questionMarkIndex + 1)].Trim(),
                    Text = line[(questionMarkIndex + 1)..].Trim()
                });
                continue;
            }

            textBuffer.Add(line);
        }

        AddParsedCard(cards, "", textBuffer);
        return cards.Count == 0 ? [new EditableTextCard()] : cards;
    }

    private static void AddParsedCard(List<EditableTextCard> cards, string heading, List<string> textLines)
    {
        var text = string.Join(Environment.NewLine, textLines).Trim();

        if (string.IsNullOrWhiteSpace(heading) && string.IsNullOrWhiteSpace(text))
            return;

        cards.Add(new EditableTextCard
        {
            Heading = heading.Trim(),
            Text = text
        });
    }

    private async Task AssignGroup()
    {
        if (selectedPageId <= 0 || selectedGroupId <= 0)
        {
            SetMessage("Bitte Seite und Bildgruppe auswählen.", "alert-warning");
            return;
        }

        await ContentPageService.AssignGalleryGroupAsync(selectedPageId, selectedGroupId);
        SetMessage("Bildgruppe wurde zugeordnet.", "alert-success");
        await LoadData();
    }

    private async Task RemoveGroup(int assignmentId)
    {
        await ContentPageService.RemoveGalleryAssignmentAsync(assignmentId);
        SetMessage("Bildgruppe wurde entfernt.", "alert-info");
        await LoadData();
    }

    private void SetMessage(string value, string cssClass)
    {
        message = value;
        messageClass = cssClass;
    }

    private static string GetPageLabel(ContentPage page)
    {
        return page.Parent is null ? page.Title : $"{page.Parent.Title} / {page.Title}";
    }

    private static string GetPublicRoute(ContentPage page)
    {
        return page.Slug switch
        {
            "startseite" => "/",
            "dokumente" => "/downloads",
            "aufnahmeerklaerung" => "/mitglied-werden",
            "mannschaftsuebersicht" => "/mannschaften",
            "mannschaften-cms" => "/mannschaften",
            "training" => "/training",
            "news" => "/news",
            "kontakt" => "/kontakt",
            "sponsoren" => "/sponsors",
            "galerie" => "/gallery",
            "links" => "/links",
            "webshop" => page.ExternalUrl ?? "https://de.butterfly.tt/",
            "weihnachtsmarkt" => "/weihnachtsmarkt",
            "impressum" => "/impressum",
            "datenschutz" => "/datenschutz",
            _ => $"/seite/{page.Slug}"
        };
    }

    private sealed class EditableTextCard
    {
        public string Heading { get; set; } = "";
        public string Text { get; set; } = "";
    }
}
