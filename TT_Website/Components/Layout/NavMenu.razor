@using TT_Website.Models
@using TT_Website.Services

@inject ContentPageService ContentPageService

<header class="site-header">
    <a class="site-brand" href="/">
        <img src="/vereinslogo.png" alt="TSV 1883 Bogen Tischtennis" />
        <strong>TSV 1883 Bogen</strong>
    </a>

    <input id="site-nav-toggle" type="checkbox" class="site-nav-toggle" />
    <label for="site-nav-toggle" class="site-nav-button" aria-label="Navigation öffnen">
        <span></span>
        <span></span>
        <span></span>
    </label>

    <nav class="site-nav" aria-label="Hauptnavigation">
        @foreach (var navPage in navPages)
        {
            var children = navPage.Children
                .OrderBy(x => x.SortOrder)
                .ToList();

            <div class="site-nav-item">
                @if (!string.IsNullOrWhiteSpace(navPage.ExternalUrl))
                {
                    <a class="site-nav-link" href="@navPage.ExternalUrl" target="_blank" rel="noopener noreferrer">
                        @navPage.Title
                    </a>
                }
                else
                {
                    <NavLink class="site-nav-link" href="@GetPageUrl(navPage)" Match="@GetMatch(navPage)">
                        @navPage.Title
                    </NavLink>
                }

                @if (children.Count > 0)
                {
                    <div class="site-nav-dropdown">
                        @foreach (var child in children)
                        {
                            @if (!string.IsNullOrWhiteSpace(child.ExternalUrl))
                            {
                                <a class="site-nav-dropdown-link" href="@child.ExternalUrl" target="_blank" rel="noopener noreferrer">
                                    @child.Title
                                </a>
                            }
                            else
                            {
                                <NavLink class="site-nav-dropdown-link" href="@GetPageUrl(child)">
                                    @child.Title
                                </NavLink>
                            }
                        }
                    </div>
                }
            </div>
        }

        <div class="site-nav-item">
            <NavLink class="site-nav-link" href="/news" Match="NavLinkMatch.Prefix">
                News
            </NavLink>
        </div>

        <div class="site-nav-item">
            <NavLink class="site-nav-link" href="/kontakt" Match="NavLinkMatch.Prefix">
                Kontakt
            </NavLink>
        </div>
    </nav>

    <div class="site-actions">
        <a class="site-join-link" href="/mitglied-werden">Mitglied werden</a>

        <AuthorizeView>
            <Authorized>
                <a class="site-admin-link" href="/admin">Admin</a>
                <form method="post" action="/admin/auth/logout">
                    <AntiforgeryToken />
                    <button type="submit" class="site-admin-button">Logout</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a class="site-admin-link" href="/admin/login">Admin Login</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</header>

@code {
    private List<ContentPage> navPages = [];

    protected override async Task OnInitializedAsync()
    {
        navPages = await ContentPageService.GetNavigationAsync();
    }

    private static string GetPageUrl(ContentPage page)
    {
        return page.Slug switch
        {
            "startseite" => "/",
            "mannschaften-cms" => "/mannschaften",
            "mannschaftsuebersicht" => "/mannschaften",
            "aufnahmeerklaerung" => "/mitglied-werden",
            "stammdatenaenderung" => "/stammdatenaenderung",
            "mitgliederentwicklung" => "/mitgliederentwicklung",
            "vereinsrangliste" => "/vereinsrangliste",
            "dokumente" => "/downloads",
            _ => $"/seite/{page.Slug}"
        };
    }

    private static NavLinkMatch GetMatch(ContentPage page)
    {
        return page.Slug == "startseite" ? NavLinkMatch.All : NavLinkMatch.Prefix;
    }
}
